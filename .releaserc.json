{
  "branches": [
    "main",
    {
      "name": "dev",
      "prerelease": "dev",
      "channel": "dev"
    }
  ],
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    "@semantic-release/changelog",
    [
      "@semantic-release/exec",
      {
        "prepareCmd": "echo 'NEXT_PUBLIC_APP_RELEASE_DATE='$(date -u '+%B %d, %Y') >> $GITHUB_ENV && echo 'NEXT_PUBLIC_APP_VERSION=${nextRelease.version}' >> $GITHUB_ENV",
        "successCmd": "if [ \"${nextRelease.channel}\" = \"dev\" ]; then ALIAS_TAG=$(echo ${nextRelease.version} | sed 's/-dev\\././' | sed 's/^/dev-v/') && git tag $ALIAS_TAG && git push origin $ALIAS_TAG; fi"
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": ["CHANGELOG.md", "package.json"],
        "message": "chore(release): ${nextRelease.version} [skip ci]"
      }
    ],
    "@semantic-release/github"
  ]
}